rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    /** True if the requester is authenticated */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** True if the requester owns this document (by uid) */
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    /** True if the requester is an admin (Phase 4 — org admin role) */
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** True if the requester is in the specified org */
    function isOrgMember(orgId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    /** True if a user profile is set to public */
    function isPublicProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.isPublicProfile == true;
    }

    // ─── User Profiles ──────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can read their own profile; others can read public profiles
      allow read: if isOwner(uid) ||
                     (isAuthenticated() && resource.data.isPublicProfile == true);

      // Only the user can create or update their own profile
      allow create: if isOwner(uid) &&
                       request.resource.data.uid == uid;

      allow update: if isOwner(uid) &&
                       // Prevent changing uid or email to someone else's
                       request.resource.data.uid == uid;

      // No deletions via client SDK — use Cloud Functions for account deletion
      allow delete: if false;

      // ── User Log Entries ─────────────────────────────────────────────────

      match /logs/{logId} {
        allow read, write: if isOwner(uid);
      }

      // ── User Badges ──────────────────────────────────────────────────────

      match /badges/{badgeId} {
        allow read: if isOwner(uid) ||
                       (isAuthenticated() && isPublicProfile(uid));
        // Badges are only written by Cloud Functions (server-side)
        allow write: if false;
      }

      // ── User Challenges ──────────────────────────────────────────────────

      match /challenges/{challengeId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) &&
                                  request.resource.data.uid == uid;
        allow delete: if isOwner(uid);
      }

      // ── AI Recommendations (cached) ──────────────────────────────────────

      match /recommendations/{recId} {
        allow read: if isOwner(uid);
        // Written only by Cloud Functions or server-side API routes
        allow write: if false;
      }

      // ── Marketplace Actions ──────────────────────────────────────────────

      match /marketplace-actions/{actionId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) &&
                        request.resource.data.uid == uid;
      }
    }

    // ─── Global Challenges (Seeded by admins) ────────────────────────────────

    match /challenges/{challengeId} {
      // All authenticated users can read challenges
      allow read: if isAuthenticated();

      // Only admins or Cloud Functions can write challenges
      allow write: if isAdmin();
    }

    // ─── Marketplace (Global actions seeded by admins) ───────────────────────

    match /marketplace/{actionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Community Feed (Phase 3) ────────────────────────────────────────────

    match /community/{postId} {
      // Authenticated users can read all posts
      allow read: if isAuthenticated();

      // Users can only create posts as themselves
      allow create: if isAuthenticated() &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.content.size() <= 280;

      // Only post author can update or delete their own post
      allow update: if isAuthenticated() &&
                       resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.uid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
                         request.resource.data.uid == request.auth.uid;
        allow delete: if isAuthenticated() &&
                         resource.data.uid == request.auth.uid;
      }

      match /likes/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && uid == request.auth.uid;
      }
    }

    // ─── Teams (Phase 3) ─────────────────────────────────────────────────────

    match /teams/{teamId} {
      allow read: if isAuthenticated() &&
                     request.auth.uid in resource.data.memberUids;
      allow create: if isAuthenticated() &&
                       request.resource.data.creatorUid == request.auth.uid;
      allow update: if isAuthenticated() &&
                       resource.data.creatorUid == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.creatorUid == request.auth.uid;
    }

    // ─── Leaderboards (Phase 3) ──────────────────────────────────────────────

    match /leaderboards/{leaderboardId} {
      allow read: if isAuthenticated();
      // Written only by Cloud Functions (aggregation triggers)
      allow write: if false;
    }

    // ─── Global Impact Counter ───────────────────────────────────────────────

    match /globalImpact/aggregate {
      allow read: if true; // Public — shown on landing page and dashboard
      allow write: if false; // Only Cloud Functions can update
    }

    // ─── Organizations (Phase 4) ─────────────────────────────────────────────

    match /organizations/{orgId} {
      allow read: if isAuthenticated() && isOrgMember(orgId);
      allow write: if isAuthenticated() && isOrgMember(orgId) &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgRole == 'admin';
    }

    // ─── Public API Keys (Phase 4) ───────────────────────────────────────────

    match /apiKeys/{keyId} {
      allow read: if isAuthenticated() &&
                     resource.data.uid == request.auth.uid;
      allow write: if false; // Created by server-side API only
    }

  }
}
